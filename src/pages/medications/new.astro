---
import Layout from "@/layouts/Layout.astro";
import AddMedicationForm from "@/components/medications/AddMedicationForm";

const error = Astro.url.searchParams.get("error");
const from = Astro.url.searchParams.get("from");
const backHref = from === "shelf" ? "/medications/shelf" : "/medications";
const backLabel = from === "shelf" ? "Back to shelf" : "Back to medications";
---

<Layout title="Add medication">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1
        class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-center text-2xl font-bold text-transparent"
      >
        Add medication
      </h1>
      <AddMedicationForm serverError={error} from={from} client:load />
      <p class="mt-4 text-center text-sm text-blue-100/60">
        <a href={backHref} class="text-purple-300 hover:underline">{backLabel}</a>
      </p>
    </div>
  </div>
</Layout>
