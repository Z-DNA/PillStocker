---
import Layout from "@/layouts/Layout.astro";
import Topbar from "@/components/Topbar.astro";
import Banner from "@/components/Banner.astro";
import { createClient } from "@/lib/supabase";
import { getActiveMedications } from "@/lib/medications/queries";
import { summarizeCabinet, type CabinetSummary } from "@/lib/medications/summary";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let summary: CabinetSummary | null = null;
let loadError: string | null = null;

if (!supabase) {
  loadError = "Supabase is not configured.";
} else {
  try {
    const meds = await getActiveMedications(supabase);
    summary = summarizeCabinet(meds, new Date());
  } catch (error) {
    console.error("Failed to load medications", error);
    loadError = "Could not load your medications. Please try again.";
  }
}
---

<Layout title="Summary">
  <div class="bg-cosmic min-h-screen p-4">
    {loadError && <Banner variant="error">{loadError}</Banner>}
    <div class="mx-auto max-w-2xl">
      <Topbar />
      <div class="mb-6">
        <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
          Summary
        </h1>
      </div>

      {
        !loadError &&
          summary &&
          (summary.total === 0 ? (
            <div class="rounded-2xl border border-white/10 bg-white/5 p-10 text-center text-white backdrop-blur-xl">
              <p class="text-lg font-medium">No medications yet</p>
              <p class="mt-1 text-sm text-blue-100/60">
                Add your first medication to start tracking run-out and expiry.
              </p>
              <a
                href="/medications/new"
                class="mt-4 inline-block rounded-lg bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
              >
                Add your first medication
              </a>
            </div>
          ) : (
            <div class="space-y-3">
              <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                <a
                  href="/medications"
                  aria-label={`${summary.runningLow} medication${summary.runningLow === 1 ? "" : "s"} running low`}
                  class="block rounded-2xl border border-white/10 bg-white/5 p-6 text-white backdrop-blur-xl transition-colors hover:bg-white/10"
                >
                  <span class="block text-4xl font-bold">{summary.runningLow}</span>
                  <span class="mt-1 block text-sm text-blue-100/70">running low</span>
                </a>
                <a
                  href="/medications/shelf"
                  aria-label={`${summary.expiringSoon} medication${summary.expiringSoon === 1 ? "" : "s"} expiring soon or expired`}
                  class="block rounded-2xl border border-white/10 bg-white/5 p-6 text-white backdrop-blur-xl transition-colors hover:bg-white/10"
                >
                  <span class="block text-4xl font-bold">{summary.expiringSoon}</span>
                  <span class="mt-1 block text-sm text-blue-100/70">expiring soon / expired</span>
                </a>
              </div>
              {summary.runningLow === 0 && summary.expiringSoon === 0 && (
                <p class="rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-center text-sm text-blue-100/80 backdrop-blur-xl">
                  All good — nothing running low or expiring soon.
                </p>
              )}
            </div>
          ))
      }
    </div>
  </div>
</Layout>
