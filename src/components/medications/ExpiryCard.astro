---
import type { ExpiryClassification, ExpiryStatus } from "@/lib/medications/expiry";
import type { MedicationRow } from "@/lib/medications/queries";

interface Props {
  med: MedicationRow;
  expiry: ExpiryClassification;
}

const { med, expiry } = Astro.props;

const presentation: Record<
  ExpiryStatus,
  { label: string; badge: string; border: string; tint: string; accent: string }
> = {
  expired: {
    label: "Expired",
    badge: "bg-red-800 text-white ring-2 ring-red-500/50",
    border: "border-red-500/70",
    tint: "bg-red-500/15",
    accent: "text-red-300",
  },
  soon: {
    label: "Soon",
    badge: "bg-amber-400 text-amber-950",
    border: "border-amber-400/60",
    tint: "bg-amber-400/10",
    accent: "text-amber-200",
  },
  ok: {
    label: "OK",
    badge: "bg-emerald-500 text-white",
    border: "border-emerald-500/60",
    tint: "bg-emerald-500/10",
    accent: "text-emerald-200",
  },
};

const p = presentation[expiry.status];

const expiryDateLabel = expiry.expiryDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

const { daysUntil } = expiry;
let relativePhrase: string;
if (daysUntil < 0) {
  const ago = Math.abs(daysUntil);
  relativePhrase = ago === 1 ? "Expired yesterday" : `Expired ${ago} days ago`;
} else if (daysUntil === 0) {
  relativePhrase = "Expires today";
} else {
  relativePhrase = daysUntil === 1 ? "Expires in 1 day" : `Expires in ${daysUntil} days`;
}
---

<div class:list={["rounded-2xl border p-5 text-white backdrop-blur-xl", p.border, p.tint]}>
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0">
      <h2 class="truncate text-lg font-semibold">
        {med.name}
        {
          med.active_substance && (
            <span class="ml-2 text-sm font-normal text-blue-100/60 italic">{med.active_substance}</span>
          )
        }
      </h2>
      {med.description && <p class="mt-1 truncate text-sm text-blue-100/40">{med.description}</p>}
    </div>
    <span class:list={["shrink-0 rounded-full px-3 py-1 text-xs font-medium", p.badge]}>{p.label}</span>
  </div>

  <div class="mt-4 flex flex-wrap items-baseline justify-between gap-2 text-sm">
    <span class:list={["font-semibold", p.accent]}>{relativePhrase}</span>
    <span class="text-blue-100/60">Expiry: {expiryDateLabel}</span>
  </div>

  <div class="mt-3 flex justify-end">
    <a href={`/medications/${med.id}/edit`} class="text-xs text-purple-300 hover:underline">Edit</a>
  </div>
</div>
